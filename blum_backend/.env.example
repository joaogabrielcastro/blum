DATABASE_URL=postgresql://user:password@host:5432/database

PORT=3011
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Obrigatório em produção: mínimo 32 caracteres
JWT_SECRET=change-me-to-a-long-random-secret
JWT_REFRESH_SECRET=change-me-too-refresh-secret
REFRESH_TOKEN_TTL_DAYS=15

# Cache distribuído (opcional)
# REDIS_URL=redis://127.0.0.1:6379
# CACHE_TTL_SECONDS=300

# Depreciação da API v1 (opcional)
# ENABLE_V1_DEPRECATION_HEADERS=true
# API_V1_SUNSET_DATE=Wed, 31 Dec 2026 23:59:59 GMT
