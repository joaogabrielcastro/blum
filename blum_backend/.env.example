# Copie para .env e preencha os valores.

# --- Obrigatório em produção ---
DATABASE_URL=postgresql://user:password@localhost:5432/blum
JWT_SECRET=0123456789abcdef0123456789abcdef

# --- Servidor ---
PORT=3011
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Multi-tenant: subdomínios por empresa (acme.blum.jwsoftware.com.br)
TENANT_BASE_DOMAIN=blum.jwsoftware.com.br
TENANT_SUBDOMAIN_ENABLED=true

# Super-admin da plataforma (e-mails separados por vírgula)
# PLATFORM_ADMIN_EMAILS=admin@jwsoftware.com.br

# --- Stripe (assinaturas SaaS) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs criados no Dashboard Stripe (Products > Prices)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_STARTER_AMOUNT=9900
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_PROFESSIONAL_AMOUNT=19900
STRIPE_PRICE_ENTERPRISE=price_...
STRIPE_PRICE_ENTERPRISE_AMOUNT=39900

# Quando true, bloqueia API sem assinatura válida (tenants legados sem Stripe continuam liberados)
BILLING_ENFORCE=false
# Métodos no Checkout: card,boleto,pix (separados por vírgula)
STRIPE_CHECKOUT_PAYMENT_METHODS=card,boleto,pix
STRIPE_BOLETO_EXPIRES_DAYS=3

# Cadastro público de novas empresas
TENANT_SIGNUP_ENABLED=true

# E-mail transacional (opcional — Resend)
# RESEND_API_KEY=re_...
# EMAIL_FROM=Blum <noreply@seudominio.com>

# Cache distribuído (opcional — serviço redis no docker-compose)
# REDIS_URL=redis://127.0.0.1:6379

# --- Opcional ---
# JWT_REFRESH_SECRET=
# CORS_ORIGINS=
# API_RATE_LIMIT_MAX=5000
