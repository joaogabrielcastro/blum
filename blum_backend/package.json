    "contract:v2": "node scripts/check_v2_contract.js",
    "perf:explain": "node scripts/perf_explain.js",
    "import:clients": "node scripts/import_clients_excel.js",
    "import:products": "node scripts/import_products_excel.js",
    "update:client-addresses": "node scripts/update_clients_address_from_excel.js",
    "backfill:client-fantasia": "node scripts/backfill_clients_nome_fantasia.js",
    "stripe:setup": "node scripts/setup-stripe-billing.js",
