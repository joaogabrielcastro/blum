{
  "name": "blum-backend",
  "version": "1.0.0",
  "description": "Backend for Blum management system",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest",
    "test:integration": "cross-env RUN_INTEGRATION=1 jest tests/integration --runInBand",
    "test:coverage": "jest --coverage",
