{
  "name": "blum-frontend",
  "version": "1.0.0",
  "description": "Frontend for Blum management system",
  "main": "src/index.js",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:ci": "react-scripts test --watchAll=false --coverage",
    "test:e2e": "cross-env RUN_E2E=1 playwright test",
    "test:e2e:install": "playwright install chromium",
    "eject": "react-scripts eject"
  },
  "dependencies": {
    "@sentry/react": "^10.65.0",
    "@tanstack/react-query": "^5.101.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.3",
    "react-scripts": "5.0.1",
    "recharts": "^3.1.2"
  },
  "overrides": {
    "underscore": "1.13.8",
    "nth-check": "2.1.1",
    "@tootallnate/once": "3.0.1",
    "serialize-javascript": "7.0.5",
    "postcss": "8.4.49",
    "rollup-plugin-terser": {
      "serialize-javascript": "7.0.5"
    },
    "css-minimizer-webpack-plugin": {
      "serialize-javascript": "7.0.5"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.14.0",
    "cross-env": "^7.0.3",
    "typescript": "4.9.5"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/utils/authSession.js",
      "src/utils/billing.js",
      "src/utils/brandSelection.js",
      "src/utils/brandUtils.js",
      "src/utils/format.js",
      "src/utils/orderFormUtils.js",
      "src/utils/orderLineTotals.js",
      "src/utils/tenantHost.js"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 80,
        "branches": 65,
        "functions": 75,
        "lines": 80
      }
    }
  }
}
