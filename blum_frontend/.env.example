# URL base da API (caminhos começam depois disto, ex.: /auth/login).
#
# Docker (Nginx na porta 8080 com proxy) ou `npm start` com src/setupProxy.js:
REACT_APP_API_URL=/api/v2
#
# Chamada direta ao backend (só funciona no mesmo PC que roda a API):
# REACT_APP_API_URL=http://localhost:3011/api/v2
#
# Produção (domínio público da API):
# REACT_APP_API_URL=https://api-blum.jwsoftware.com.br/api/v2
#
# Multi-tenant (subdomínios e onboarding Stripe)
# REACT_APP_TENANT_BASE_DOMAIN=blum.jwsoftware.com.br
# REACT_APP_TENANT_DEV_SLUG=acme
#
# Alvo do proxy em desenvolvimento (opcional):
# REACT_APP_DEV_PROXY_TARGET=http://127.0.0.1:3011

# --- Observabilidade (Fase 1 — opcional) ---
# REACT_APP_SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
# REACT_APP_SENTRY_ENVIRONMENT=development
# REACT_APP_SENTRY_RELEASE=blum-frontend@local
# REACT_APP_SENTRY_TRACES_SAMPLE_RATE=0.1
# REACT_APP_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
# REACT_APP_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1
# REACT_APP_GIT_SHA=
