# URL base da API (caminhos começam depois disto, ex.: /auth/login).
#
# Docker (Nginx na porta 8080 com proxy) ou `npm start` com src/setupProxy.js:
REACT_APP_API_URL=/api/v2
#
# Chamada direta ao backend (só funciona no mesmo PC que roda a API):
# REACT_APP_API_URL=http://localhost:3011/api/v2
#
# Produção (domínio público da API):
# REACT_APP_API_URL=https://api-blum.jwsoftware.com.br/api/v2
#
# Alvo do proxy em desenvolvimento (opcional):
# REACT_APP_DEV_PROXY_TARGET=http://127.0.0.1:3011
