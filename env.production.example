# Modelo para docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
# Não commitar .env.production com secrets reais.

# --- Postgres (se usar serviço do compose) ---
POSTGRES_USER=blum
POSTGRES_PASSWORD=altere_uma_senha_forte
POSTGRES_DB=blum
DATABASE_URL=postgresql://blum:altere_uma_senha_forte@postgres:5432/blum

# --- Backend ---
JWT_SECRET=gerar_com_openssl_rand_hex_32
FRONTEND_URL=https://blum.jwsoftware.com.br
TENANT_BASE_DOMAIN=blum.jwsoftware.com.br
TENANT_SUBDOMAIN_ENABLED=true
TENANT_SIGNUP_ENABLED=true
PLATFORM_ADMIN_EMAILS=admin@jwsoftware.com.br
CORS_ORIGINS=
BILLING_ENFORCE=true
TRUST_PROXY=1

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...
STRIPE_CHECKOUT_PAYMENT_METHODS=card,boleto,pix

# E-mail (opcional — Resend)
RESEND_API_KEY=
EMAIL_FROM=Blum <noreply@jwsoftware.com.br>

# Redis (opcional)
REDIS_URL=redis://redis:6379

# Observabilidade (opcional — Sentry / OTel)
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# OTEL_SERVICE_NAME=blum-backend
# OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Frontend build (Coolify: serviços separados) ---
# Recomendado: URL pública da API — o browser não depende do proxy Nginx /api/.
REACT_APP_API_URL=https://api-blum.jwsoftware.com.br/api/v2
REACT_APP_TENANT_BASE_DOMAIN=blum.jwsoftware.com.br
REACT_APP_ONBOARDING_PLAN_SLUG=starter
# REACT_APP_SENTRY_DSN=
# REACT_APP_SENTRY_ENVIRONMENT=production
# REACT_APP_SENTRY_RELEASE=
# REACT_APP_GIT_SHA=
# Só se usar REACT_APP_API_URL=/api/v2 no mesmo host: hostname interno do container API na rede Docker.
# BACKEND_PROXY_HOST=nome-interno-do-servico-api

# Portas expostas (opcional)
BACKEND_PORT=3011
FRONTEND_PORT=8080
