# Copie para .env.production na raiz do repositório e preencha.
# docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build

POSTGRES_USER=blum
POSTGRES_PASSWORD=
POSTGRES_DB=blum

# URL do Postgres dentro do Compose (serviço "postgres")
DATABASE_URL=postgresql://blum:SUA_SENHA@postgres:5432/blum

# Mínimo 32 caracteres (ex.: openssl rand -hex 32)
JWT_SECRET=

# URL pública do frontend (CORS)
FRONTEND_URL=https://app.seudominio.com.br

# Opcional: outras origens permitidas
# CORS_ORIGINS=https://staging.seudominio.com.br

# URL pública da API para o build do React (sem barra final)
REACT_APP_API_URL=https://api.seudominio.com.br/api/v1

# Portas no host (opcional)
# BACKEND_PORT=3011
# FRONTEND_PORT=8080

TRUST_PROXY=1
