# Control Plane — Fase 2
PORT=3020
NODE_ENV=development

# Banco dedicado (criado automaticamente na subida se não existir)
DATABASE_URL=postgresql://blum:blum_docker_dev@127.0.0.1:5433/agent_control

# Redis (fila de ingestão). Sem REDIS_URL, processa ingestão inline.
REDIS_URL=redis://127.0.0.1:6379

# Token do painel / API admin (Bearer)
CONTROL_PLANE_ADMIN_TOKEN=dev-admin-token-change-me

# Seed do projeto Blum no primeiro boot (opcional)
SEED_PROJECT_SLUG=blum
SEED_PROJECT_NAME=Blum
SEED_PROJECT_REPO=joaogabrielcastro/blum

# --- Fase 3: diagnóstico automático ---
# Prioridade automática: CURSOR_API_KEY > LLM_* > heurística
# DIAGNOSIS_PROVIDER=auto|cursor|llm|openai|gemini|heuristic
#
# Cursor SDK (recomendado) — chave em https://cursor.com/dashboard/integrations
# CURSOR_API_KEY=cursor_...
# CURSOR_MODEL=composer-2.5
# CURSOR_RUNTIME=cloud
# CURSOR_REPO_URL=https://github.com/joaogabrielcastro/blum
# CURSOR_LOCAL_CWD=   # só se CURSOR_RUNTIME=local
#
# Sem chave LLM/Cursor, usa heurística local (sempre disponível).
# LLM_PROVIDER=openai|gemini
# LLM_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1
# GITHUB_TOKEN=  # opcional — leitura de arquivos + poll de CI (Fase 5); nunca merge
# DIAGNOSIS_COOLDOWN_MINUTES=30

# --- Fase 5: PR após approve ---
# PR_ON_APPROVE=true
# CURSOR_PR_TIMEOUT_MS=420000

# --- Notificações Telegram (celular) ---
# 1) Fale com @BotFather → /newbot → copie o token
# 2) Envie /start para o bot
# 3) Abra https://api.telegram.org/bot<TOKEN>/getUpdates e copie o chat.id
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_NOTIFY=true
# CONTROL_PLANE_PUBLIC_URL=http://localhost:3020
